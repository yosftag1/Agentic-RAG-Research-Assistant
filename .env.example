# ─── LLM Provider ───────────────────────────────────────────────
GOOGLE_API_KEY=AIza...

# Model to use for chat completions (default: gemini-2.0-flash)
LLM_MODEL=gemini-2.0-flash

# Model to use for embeddings (default: models/embedding-001)
EMBEDDING_MODEL=models/gemini-embedding-001

# ─── Optional: Tavily Web Search ────────────────────────────────
# TAVILY_API_KEY=tvly-...

# ─── RAG Settings ───────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5

# ─── Paths ──────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
DOCUMENT_DIR=./data
